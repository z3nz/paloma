{
  "name": "paloma",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "bash scripts/paloma-sync.sh && npm install && bash scripts/setup-mcp.sh && node scripts/paloma-supervisor.js",
    "supervisor": "node scripts/paloma-supervisor.js",
    "first-run": "bash scripts/first-run.sh",
    "setup": "bash scripts/setup-mcp.sh",
    "postinstall": "bash scripts/setup-mcp.sh",
    "dev": "vite",
    "bridge": "node bridge/run.js",
    "bridge:direct": "node bridge/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "doctor": "node scripts/paloma-doctor.js",
    "pull-models": "bash scripts/pull-models.sh",
    "test": "node --test tests/*.test.js bridge/__tests__/*.test.js",
    "test:email": "node --test tests/email-watcher.test.js"
  },
  "bin": {
    "paloma": "scripts/paloma-cli.sh"
  },
  "dependencies": {
    "@kevinwatt/shell-mcp": "^0.4.17",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@modelcontextprotocol/server-brave-search": "^0.6.2",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@mseep/git-mcp-server": "^2.1.4",
    "@playwright/mcp": "^0.0.68",
    "@tailwindcss/vite": "4.0",
    "@thelord/mcp-cloudflare": "^1.6.0",
    "dexie": "^4.3.0",
    "diff": "^8.0.3",
    "dompurify": "^3.3.3",
    "express": "^5.1.0",
    "fuse.js": "^7.1.0",
    "googleapis": "^144.0.0",
    "highlight.js": "^11.11.1",
    "ignore": "^7.0.5",
    "marked": "^17.0.1",
    "mongodb": "^7.1.0",
    "tailwindcss": "4.0",
    "vue": "^3.5.24",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "vite": "^8.0.10",
    "wrangler": "^4.83.0"
  }
}
