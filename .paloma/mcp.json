{
  "enabled": [
    "brave-search",
    "git",
    "shell",
    "filesystem",
    "web",
    "fs-extra",
    "codex",
    "voice",
    "memory",
    "ollama",
    "gmail"
  ],
  "autoExecute": [
    "brave-search",
    "filesystem",
    {
      "server": "shell",
      "tools": [
        "shell_find",
        "shell_whereis",
        "shell_nslookup",
        "shell_dig",
        "shell_grep",
        "shell_ps"
      ]
    },
    {
      "server": "git",
      "tools": [
        "git_diff",
        "git_log",
        "git_status",
        "git_set_working_dir",
        "git_show",
        "git_commit",
        "git_add"
      ]
    },
    {
      "server": "cloudflare-dns",
      "tools": [
        "list_dns_records"
      ]
    },
    {
      "server": "web",
      "tools": [
        "web_fetch"
      ]
    },
    {
      "server": "exec",
      "tools": [
        "bash_exec"
      ]
    },
    "codex",
    "fs-extra",
    "voice",
    "memory",
    {
      "server": "ollama",
      "tools": [
        "ollama_list_models",
        "ollama_embed",
        "ollama_chat"
      ]
    },
    {
      "server": "gmail",
      "tools": [
        "email_read",
        "email_list",
        "email_check_thread",
        "email_wait",
        "email_reply"
      ]
    }
  ]
}
